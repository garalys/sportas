# ---------------------------------------------------------------------------
# Supabase (client-side — safe to expose, they are the public anon keys)
# Find these in: Supabase Dashboard -> Project Settings -> API
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ---------------------------------------------------------------------------
# OpenAI (server-side only — used by the /api/analyze-food serverless route)
# NEVER prefix this with VITE_ or it will be bundled into the client.
# Leave blank for now; the food-photo feature falls back to a mock response.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
